  <property name="styleSheet">
   <string notr="true">/* ========== 全局背景 ========== */
QMainWindow {
    background-color: #f0f2f5;
}

/* ========== 全局字体基准 ========== */
QWidget {
    font: 12pt &quot;Segoe UI&quot;;
}

/* ========== 工具栏 ========== */
QToolBar {
    background-color: #ffffff;
    border-bottom: 1px solid #d0d7de;
    padding: 6px 12px;
    spacing: 12px;
}
QToolBar QToolButton {
    background-color: #f8f9fc;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 8px 16px;
    font: 12pt &quot;Segoe UI&quot;;
    min-width: 80px;
    min-height: 32px;
    color: #1e293b;
}
QToolBar QToolButton:hover {
    background-color: #e9ecef;
    border-color: #94a3b8;
}
QToolBar QToolButton:pressed {
    background-color: #dee2e6;
}

/* ========== 左侧用例树 ========== */
QTreeWidget {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    font: 12pt &quot;Segoe UI&quot;;
    outline: 0;
    padding: 8px;
    margin: 8px 4px 8px 8px;
}
QTreeWidget::item {
    height: 34px;
    border-radius: 4px;
    margin: 2px 0;
}
QTreeWidget::item:hover {
    background-color: #f1f5f9;
}
QTreeWidget::item:selected {
    background-color: #e0e7ff;
    color: #1e40af;
}

/* ========== 标签页 ========== */
QTabWidget::pane {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    margin-top: -1px;
}
QTabWidget::tab-bar {
    alignment: left;
}
QTabBar::tab {
    background-color: #f8fafc;
    padding: 10px 24px;
    margin-right: 4px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border: 1px solid #cbd5e1;
    border-bottom: none;
    font: 12pt &quot;Segoe UI&quot;;
    color: #334155;
}
QTabBar::tab:selected {
    background-color: #ffffff;
    border-bottom: 2px solid #3b82f6;
    font-weight: bold;
    color: #0f172a;
}
QTabBar::tab:hover:!selected {
    background-color: #e2e8f0;
}

/* ========== GroupBox（确保边框完整） ========== */
QGroupBox {
    font: bold 12pt &quot;Segoe UI&quot;;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    margin-top: 14px;
    padding-top: 14px;
    background-color: #ffffff;
    margin-bottom: 10px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 8px;
    background-color: #ffffff;
    color: #1e293b;
}

/* ========== 普通标签：字体统一为12pt，与全局基准一致 ========== */
QLabel {
    font: 12pt &quot;Segoe UI&quot;;
    color: #2c3e50;
}

/* ========== 按钮 ========== */
QPushButton {
    background-color: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 8px 16px;
    font: 11pt &quot;Segoe UI&quot;;
    min-width: 80px;
    min-height: 32px;
    color: #1e293b;
}
QPushButton:hover {
    background-color: #e9ecef;
    border-color: #94a3b8;
}
QPushButton:pressed {
    background-color: #dee2e6;
}

/* ========== 表格 ========== */
QTableWidget {
    background-color: #ffffff;
    alternate-background-color: #fafcff;
    gridline-color: #e2e8f0;
    font: 11pt &quot;Segoe UI&quot;;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
}
/* 表头标题字体最大，并加粗 */
QHeaderView::section {
    background-color: #f1f5f9;
    padding: 6px;
    border: 1px solid #e2e8f0;
    font-weight: bold;
    font-size: 11pt;
    color: #0f172a;
}
QTableWidget::item {
    padding: 6px;
}

/* ========== 进度条 ========== */
QProgressBar {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    text-align: center;
    background-color: #f1f5f9;
    font: 11pt &quot;Segoe UI&quot;;
    height: 26px;
}
QProgressBar::chunk {
    background-color: #3b82f6;
    border-radius: 6px;
}

/* ========== 状态栏 ========== */
QStatusBar {
    background-color: #ffffff;
    border-top: 1px solid #cbd5e1;
    font: 10pt &quot;Segoe UI&quot;;
    padding: 4px;
    color: #475569;
}

/* ========== 滚动区域 ========== */
QScrollArea {
    border: none;
    background-color: transparent;
}

/* ========== 表单布局 ========== */
QFormLayout {
    spacing: 10px;
}

/* ========== 复选框 ========== */
QCheckBox {
    font: 11pt &quot;Segoe UI&quot;;
    spacing: 8px;
}

/* ========== 输入控件 ========== */
QComboBox, QSpinBox, QDoubleSpinBox, QLineEdit {
    font: 11pt &quot;Segoe UI&quot;;
    padding: 5px;
    border: 1px solid #cbd5e1;
    border-radius: 5px;
    background-color: #ffffff;
    min-height: 28px;
}
QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus, QLineEdit:focus {
    border: 1px solid #3b82f6;
}

/* ========== 特殊调整：让表格内的“导出CSV”等按钮行距合适 ========== */
QPushButton#exportCsvBtn, QPushButton#saveScreenshotBtn, QPushButton#viewHistoryBtn,
QPushButton#exportBtn, QPushButton#clearLogBtn, QPushButton#exportLogBtn {
    padding: 6px 12px;
    min-width: 70px;
}
QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    width: 28px;
}</string>
